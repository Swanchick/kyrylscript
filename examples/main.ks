function sum(a: int, b: int): int {
    return a + b;
}

function difference(a: int, b: int): int {
    return a - b;
}

function multiplication(a: int, b: int): int {
    return a * b;
}

function division(a: int, b: int): float {
    return a / b;
}


let result1 = sum(10, 20);
let result2 = difference(10, 20);
let result3 = multiplication(10, 20);
let result4 = division(10, 20);
